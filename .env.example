## Root `.env` (docker-compose reads this file from repo root)
# Copy to `.env` when running Docker.
# For running without Docker:
# - Backend uses `backend/.env.development` or `backend/.env.production` (set `NODE_ENV`).
# - Frontend uses `frontend/.env.development` and `frontend/.env.production` automatically.

DB_NAME=activetor
DB_USER=activetor_user
DB_PASS=replace_with_strong_password
# In docker-compose, backend connects to postgres service, so host is `postgres`.
DB_HOST=postgres
JWT_SECRET=replace_with_strong_jwt_secret
PORT=5000

KAVENEGAR_API_KEY=replace_with_kavenegar_api_key
KAVENEGAR_TEMPLATE=verify
KAVENEGAR_TYPE=sms
OTP_EXPIRE_MINUTES=2
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Contract expiry reminder SMS (admin toggle + cron job)
# Requires a Kavenegar Lookup template you create in Kavenegar panel
KAVENEGAR_CONTRACT_EXPIRE_TEMPLATE=contract
SMS_CONTRACT_EXPIRY_ENABLED_DEFAULT=false
SMS_CONTRACT_EXPIRY_DAYS_BEFORE_END=5
SMS_CONTRACT_EXPIRY_CRON=12 12 * * *
SMS_CRON_TZ=Asia/Tehran
